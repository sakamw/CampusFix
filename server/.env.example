# Django
DEBUG=True
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Secret key (generate a new one for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Redis (optional; set CAMPUSFIX_USE_REDIS=1 to enable)
CAMPUSFIX_USE_REDIS=0
CAMPUSFIX_REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CAMPUSFIX_REDIS_CHANNEL_HOST=127.0.0.1
CAMPUSFIX_REDIS_CHANNEL_PORT=6379

# Gemini AI (optional; AI features degrade gracefully if not set)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_ISSUES=models/gemini-1.5-flash
# use a free-tier model when quota on the primary model is exceeded
# default uses `gemini-1.5-flash` which has daily free tier quota
# this model is tried first if primary model hits quota
GEMINI_FREE_MODEL=models/gemini-1.5-flash

# Email (optional)
# SENDGRID_API_KEY=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com