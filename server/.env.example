# Django
DEBUG=True
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Secret key (replace with a secure value in production)
SECRET_KEY=your-secret-key-here

# Redis (optional; set CAMPUSFIX_USE_REDIS=1 to enable)
CAMPUSFIX_USE_REDIS=0
CAMPUSFIX_REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CAMPUSFIX_REDIS_CHANNEL_HOST=127.0.0.1
CAMPUSFIX_REDIS_CHANNEL_PORT=6379

# Gemini AI (optional; AI features degrade gracefully if not set)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_ISSUES=models/gemini-1.5-flash
GEMINI_FREE_MODEL=models/gemini-1.5-flash

# Email
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
SITE_URL=http://localhost:8000